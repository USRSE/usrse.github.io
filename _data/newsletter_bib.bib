@article{kaiserProbabilisticComputingPbits2021,
  title = {Probabilistic Computing with P-Bits},
  author = {Kaiser, Jan and Datta, Supriyo},
  date = {2021-10-11},
  journaltitle = {Applied Physics Letters},
  volume = {119},
  number = {15},
  eprint = {2108.09836},
