# Copy this file to .env.local and fill in real values.
# Anything prefixed VITE_ is bundled into the browser — never put secrets here.

# WorkOS AuthKit — public client identifier, safe to ship to the browser.
VITE_WORKOS_CLIENT_ID=

# Where AuthKit redirects after sign-in. Must exactly match a redirect URI
# configured in the WorkOS dashboard (Authentication → Redirects).
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback
