# Copy this file to .env.local and fill in real values.
# Anything prefixed VITE_ is bundled into the browser — never put secrets here.

# WorkOS AuthKit — public client identifier, safe to ship to the browser.
# The redirect URI is derived at runtime as `${window.location.origin}/auth/callback`,
# so register every origin you deploy to (localhost, preview, production) in the
# WorkOS dashboard under Authentication → Redirects.
VITE_WORKOS_CLIENT_ID=

# Override the API base URL. Leave unset to hit the deployed Cloudflare
# Worker (production behavior). Set to http://localhost:8787 to point
# at a local `wrangler dev` instance — required when iterating on
# backend code in packages/api so changes are actually exercised.
VITE_API_BASE_URL=

# Override the admin app URL used by the "Admin portal" dropdown link.
# Leave unset to get the right default for the build mode (prod →
# https://admin.us-rse.org, vite dev → http://localhost:5174). Set
# explicitly to point at a preview deploy.
VITE_ADMIN_URL=
