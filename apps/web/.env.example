# Copy this file to .env.local and fill in real values.
# Anything prefixed VITE_ is bundled into the browser — never put secrets here.

# WorkOS AuthKit — public client identifier, safe to ship to the browser.
# The redirect URI is derived at runtime as `${window.location.origin}/auth/callback`,
# so register every origin you deploy to (localhost, preview, production) in the
# WorkOS dashboard under Authentication → Redirects.
VITE_WORKOS_CLIENT_ID=
